{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/FiveTalents.Api/FiveTalents.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "watch: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/FiveTalents.Api/FiveTalents.Api.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" }
    },
    {
      "label": "start: mailpit",
      "type": "shell",
      "command": "mailpit",
      "isBackground": true,
      "problemMatcher": {
        "owner": "mailpit",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[smtpd\\]",
          "endsPattern": "accessible via"
        }
      },
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "stop: mailpit",
      "type": "shell",
      "command": "Stop-Process -Name mailpit -ErrorAction SilentlyContinue",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "stop: angular",
      "type": "shell",
      "command": "Get-NetTCPConnection -LocalPort 4200 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "stop: all",
      "dependsOn": ["stop: mailpit", "stop: angular"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "pre-launch: full stack",
      "dependsOn": ["build: api", "start: mailpit"],
      "dependsOrder": "parallel",
      "group": "build"
    },
    {
      "label": "serve: angular",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}/web/five-talents-web"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular",
        "pattern": { "regexp": "^(.*)$", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Local:.*http://localhost"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" }
    }
  ]
}
