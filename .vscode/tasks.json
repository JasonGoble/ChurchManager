{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/FiveTalents.Api/FiveTalents.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "watch: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/FiveTalents.Api/FiveTalents.Api.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" }
    },
    {
      "label": "start: db",
      "type": "shell",
      "command": "docker compose up db -d --wait",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "pre-launch: full stack",
      "dependsOn": ["build: api", "start: mailpit", "start: db"],
      "dependsOrder": "parallel",
      "group": "build"
    },
    {
      "label": "start: mailpit",
      "type": "shell",
      "command": "docker compose up mailpit -d --wait",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "serve: angular",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}/web/five-talents-web"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "angular",
        "pattern": { "regexp": "^(.*)$", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Local:.*http://localhost"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" }
    }
  ]
}
